# Dependencies
node_modules/
/dist/
/.next/
/out/
/build/

# Genkit & AI Traces (NEW: Prevents the trace flood)
.genkit/
**/traces/
**/traces_idx/

# Firebase
.firebase/
firebase-debug.log*
ui-debug.log*
firestore-debug.log*
pubsub-debug.log*
functions/node_modules/
functions/lib/
functions/dist/

# SECRETS
.env
.env*.local
service_account_key.json
# Better to ignore specific secret JSONs than all *.json
# *.json  <-- Removed this broad rule to avoid issues with workspace configs

# Specific JSONs to ignore (Add others as needed)
secrets.json
credentials.json

# Keep these (Explicitly allowed)
!package.json
!package-lock.json
!tsconfig.json
!firebase.json
!storage.rules
!firestore.rules

# Vercel & IDE
.vercel
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
