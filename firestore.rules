/**
 * @fileoverview Firestore Security Rules for the Okidex Investment Match Platform.
 *
 * Core Philosophy:
 * This ruleset employs a strict ownership model for user data and a combination of ownership and shared access for other data types.
 * Access is granted based on user authentication and explicit ownership or membership. Data structure is designed to avoid
 * complex queries in rules.
 *
 * Data Structure:
 * - /users/{userId}: User profiles, accessible only by the owning user.
 * - /users/{userId}/userProfiles/{profileId}: User profile information, accessible only by the owning user. The profileId MUST match the userId.
 * - /startups/{startupId}: Startup information, open read access, restricted writes. The 'founderId' field in the document must match the user attempting to create/update/delete.
 * - /investmentTheses/{investmentThesisId}: Investment theses, open read access, restricted writes. The 'investorId' field in the document must match the user attempting to create/update/delete.
 * - /jobPostings/{jobPostingId}: Job postings, open read access, restricted writes.
 * - /matches/{matchId}: Match information between users.
 * - /matches/{matchId}/messages/{messageId}: Messages between matched users, accessible only to users involved in the match.
 * - /startups/{startupId}/financialData/{financialDataId}: Financial data for startups.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Read-only collections leverage `allow get, list: if true;`.
 * - Ambiguous relationships default to strict owner-only access.
 *
 * Denormalization for Authorization:
 * - Ownership is enforced by requiring relevant documents to contain the user's ID (e.g., 'founderId' on Startup, 'investorId' on InvestmentThesis) and matching these IDs against `request.auth.uid`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is made by an authenticated user.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     * @param {string} userId - The user ID to check against.
     * @return {bool} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource and the resource exists.
     * @param {string} userId - The user ID to check against.
     * @return {bool} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for the /users/{userId} collection.
     * @path /users/{userId}
     * @allow (create) User with ID 'test_user' can create their own user document.
     * @deny (create) User with ID 'test_user' cannot create a user document with ID 'other_user'.
     * @allow (get) User with ID 'test_user' can get their own user document.
     * @deny (get) User with ID 'test_user' cannot get a user document with ID 'other_user'.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/userProfiles/{profileId} collection.
     * @path /users/{userId}/userProfiles/{profileId}
     * @allow (create) User with ID 'test_user' can create their own user profile with the same ID.
     * @deny (create) User with ID 'test_user' cannot create a user profile with ID 'other_user'.
     * @allow (get) User with ID 'test_user' can get their own user profile with the same ID.
     * @deny (get) User with ID 'test_user' cannot get a user profile with ID 'other_user'.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId}/userProfiles/{profileId} {
      allow get: if isOwner(userId) && userId == profileId;
      allow list: if isOwner(userId) && userId == profileId;
      allow create: if isOwner(userId) && userId == profileId && request.resource.data.id == profileId;
      allow update: if isExistingOwner(userId) && userId == profileId && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId) && userId == profileId;
    }

    /**
     * @description Rules for the /startups/{startupId} collection.
     * @path /startups/{startupId}
     * @allow (get) Any user can read startup information.
     * @deny (create) Only authenticated users can create a startup and they must be the founder.
     * @deny (update) Only the founder can update the startup.
     * @deny (delete) Only the founder can delete the startup.
     * @principle Allows public read access but restricts write access to the founder.
     */
    match /startups/{startupId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.founderId == request.auth.uid;
      allow update: if isSignedIn() && resource != null && resource.data.founderId == request.auth.uid;
      allow delete: if isSignedIn() && resource != null && resource.data.founderId == request.auth.uid;
    }

    /**
     * @description Rules for the /investmentTheses/{investmentThesisId} collection.
     * @path /investmentTheses/{investmentThesisId}
     * @allow (get) Any user can read investment theses.
     * @deny (create) Only investors can create an investment thesis.
     * @deny (update) Only the investor can update their investment thesis.
     * @deny (delete) Only the investor can delete their investment thesis.
     * @principle Allows public read access but restricts write access to the investor.
     */
    match /investmentTheses/{investmentThesisId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.investorId == request.auth.uid;
      allow update: if isSignedIn() && resource != null && resource.data.investorId == request.auth.uid;
      allow delete: if isSignedIn() && resource != null && resource.data.investorId == request.auth.uid;
    }

    /**
     * @description Rules for the /jobPostings/{jobPostingId} collection.
     * @path /jobPostings/{jobPostingId}
     * @allow (get) Any user can read job postings.
     * @deny (create) Only authenticated users can create a job posting.
     * @deny (update) No one can update a job posting.
     * @deny (delete) No one can delete a job posting.
     */
    match /jobPostings/{jobPostingId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for the /matches/{matchId} collection.
     * @path /matches/{matchId}
     */
    match /matches/{matchId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for the /matches/{matchId}/messages/{messageId} collection.
     * @path /matches/{matchId}/messages/{messageId}
     */
    match /matches/{matchId}/messages/{messageId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for the /startups/{startupId}/financialData/{financialDataId} collection.
     * @path /startups/{startupId}/financialData/{financialDataId}
     */
    match /startups/{startupId}/financialData/{financialDataId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }
  }
}
