rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // FETCH THE SEARCHER'S DATA
    function getSearcher() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // ROLE-BASED VISIBILITY (Refactored to avoid 'let' and nested function issues)
    function canSearchUser(targetData) {
      return (getSearcher().role == 'talent' && (
        targetData.role == 'founder' ||
        (targetData.role == 'investor' && targetData.isHiring == true) ||
        (targetData.role == 'talent' && getSearcher().isLookingForCoFounder == true && targetData.isLookingForCoFounder == true)
      )) ||
      (getSearcher().role == 'founder' && (
        targetData.role == 'talent' ||
        (targetData.role == 'founder' && getSearcher().isLookingForCoFounder == true && targetData.isLookingForCoFounder == true)
      )) ||
      (getSearcher().role == 'investor' && (
        targetData.role == 'investor' ||
        targetData.role == 'talent' ||
        (targetData.role == 'founder' && targetData.okiPlusActive == true)
      ));
    }
    
    function isParticipant() {
      return isSignedIn() && request.auth.uid in resource.data.participantIds;
    }
    function willBeParticipant() {
      return isSignedIn() && request.auth.uid in request.resource.data.participantIds;
    }

    // --- USERS & SEARCHABLE PROFILES ---
    match /users/{userId} {
      allow create, update: if isOwner(userId);
      allow delete: if false;

      allow read: if isSignedIn() && (
        isOwner(userId) || canSearchUser(resource.data)
      );
    }
    
    match /user_profiles/{profileId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- NOTIFICATIONS ---
    match /notifications/{notificationId} {
      allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // --- MESSAGING & CONVERSATIONS ---
    match /conversations/{conversationId} {
      allow read: if isParticipant();
      allow create: if willBeParticipant();
      allow update: if isParticipant() || willBeParticipant();

      match /messages/{messageId} {
        allow read, write: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }

    // --- MATCHES (FIXED: Added support for array-contains queries) ---
    match /matches/{matchId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if willBeParticipant();
      allow update: if isParticipant() || willBeParticipant();
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.participantIds;
      }
    }

    // --- DISCOVERY COLLECTIONS ---
    match /startups/{startupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.founderIds;
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.founderIds ||
        request.auth.uid in request.resource.data.founderIds
      );
    }

    match /theses/{thesisId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.investorId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.investorId == request.auth.uid;
    }
    
    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.founderId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.founderId == request.auth.uid;
    }

    match /interests/{interestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- GLOBAL FALLBACK ---
    match /{collection}/{docId} {
      allow read: if collection in [
        'job_postings',
        'investment_opportunities',
        'investment_theses',
        'startups'
      ] && isSignedIn();
      allow write: if false;
    }
  }
}
