/**
 * @file Firebase Security Rules for Okidex Application
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user-related data
 * and open access to publicly-listed data, while using path-based ownership to
 * secure data trees. For other entities, it assumes a public read model, but
 * enforces ownership for create/update/delete operations via an `ownerId` field.
 *
 * Data Structure:
 * - /users/{userId}: Stores user data, accessible only by the user.
 * - /users/{userId}/userProfiles/{profileId}: Stores user profile data, accessible only by the user.
 * - /startups/{startupId}: Stores startup data, readable by all, but writable only by the owner.
 * - /investmentTheses/{investmentThesisId}: Stores investment theses, readable by all, but writable only by the owner.
 * - /jobPostings/{jobPostingId}: Stores job postings, readable by all, but writable only by the owner.
 * - /matches/{matchId}: Stores match data, readable by all, but writable only by the owner.
 * - /matches/{matchId}/messages/{messageId}: Stores messages for matches, accessible only to users in the match.
 * - /startups/{startupId}/financialData/{financialDataId}: Stores financial data for startups, accessible only to those with access to the startup.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect user privacy.
 * - Ambiguous relationships default to owner-only access.
 * - All write operations require a verified user identity (request.auth != null).
 * - Public read access is enabled for certain top-level collections but guarded
 *   by owner-only write access.
 *
 * Denormalization for Authorization:
 * - The rules rely on path-based ownership for /users/{userId} and
 *   /users/{userId}/userProfiles/{profileId}, avoiding the need for get() calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures the /users/{userId} collection, ensuring only the user can access their data.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their document.
     * @allow (get) User with ID 'user123' can read their document.
     * @allow (update) User with ID 'user123' can update their document.
     * @allow (delete) User with ID 'user123' can delete their document.
     * @deny (create) User with ID 'user456' cannot create a document for 'user123'.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isSignedIn() && isOwner(userId) && request.auth.uid == userId;
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Secures the /users/{userId}/userProfiles/{profileId} collection, ensuring only the user can access their profile data.
     * @path /users/{userId}/userProfiles/{profileId}
     * @allow (create) User with ID 'user123' can create a profile document under their user document.
     * @allow (get) User with ID 'user123' can read their profile document.
     * @allow (update) User with ID 'user123' can update their profile document.
     * @allow (delete) User with ID 'user123' can delete their profile document.
     * @deny (create) User with ID 'user456' cannot create a profile document for 'user123'.
     * @principle Enforces document ownership for writes within a user's data tree.
     */
    match /users/{userId}/userProfiles/{profileId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Secures the /startups/{startupId} collection, allowing public read access but restricting writes to the owner.
     * @path /startups/{startupId}
     * @allow (get) Any user can read a startup document.
     * @allow (list) Any user can list startup documents.
     * @allow (create) User with ID 'user123' can create a startup document with 'founderId' set to 'user123'.
     * @allow (update) User with ID 'user123' can update a startup document where 'founderId' is 'user123'.
     * @allow (delete) User with ID 'user123' can delete a startup document where 'founderId' is 'user123'.
     * @deny (create) User with ID 'user456' cannot create a startup document with 'founderId' set to 'user123'.
     * @principle Allows public read access with owner-only writes.
     */
    match /startups/{startupId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner() {
        return isSignedIn() && request.auth.uid == resource.data.founderId;
      }

      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && request.resource.data.founderId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.founderId == request.auth.uid;
      allow delete: if isSignedIn() && request.resource.data.founderId == request.auth.uid;
    }

    /**
     * @description Secures the /investmentTheses/{investmentThesisId} collection, allowing public read access but restricting writes to the owner.
     * @path /investmentTheses/{investmentThesisId}
     * @allow (get) Any user can read an investment thesis document.
     * @allow (list) Any user can list investment thesis documents.
     * @allow (create) User with ID 'user123' can create an investment thesis document with 'investorId' set to 'user123'.
     * @allow (update) User with ID 'user123' can update an investment thesis document where 'investorId' is 'user123'.
     * @allow (delete) User with ID 'user123' can delete an investment thesis document where 'investorId' is 'user123'.
     * @deny (create) User with ID 'user456' cannot create an investment thesis document with 'investorId' set to 'user123'.
     * @principle Allows public read access with owner-only writes.
     */
    match /investmentTheses/{investmentThesisId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner() {
        return isSignedIn() && request.auth.uid == resource.data.investorId;
      }

      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && request.resource.data.investorId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.investorId == request.auth.uid;
      allow delete: if isSignedIn() && request.resource.data.investorId == request.auth.uid;
    }

    /**
     * @description Secures the /jobPostings/{jobPostingId} collection, allowing public read access but restricting writes to the owner.
     * @path /jobPostings/{jobPostingId}
     * @allow (get) Any user can read a job posting document.
     * @allow (list) Any user can list job posting documents.
     * @deny (create) User can not create a job posting, requires startup id relationship to validate access
     * @principle Allows public read access with owner-only writes.
     */
    match /jobPostings/{jobPostingId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner() {
        return isSignedIn() && request.auth.uid == resource.data.ownerId;
      }

      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if isSignedIn() && request.resource.data.ownerId == request.auth.uid; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if isSignedIn() && request.resource.data.ownerId == request.auth.uid; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Secures the /matches/{matchId} collection, allowing public read access but restricting writes to the owner.
     * @path /matches/{matchId}
     * @allow (get) Any user can read a match document.
     * @allow (list) Any user can list match documents.
     * @deny (create) User can not create a match, requires user id relationship to validate access
     * @principle Allows public read access with owner-only writes.
     */
    match /matches/{matchId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner() {
        return isSignedIn() && request.auth.uid == resource.data.ownerId;
      }

      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if isSignedIn() && request.resource.data.ownerId == request.auth.uid; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if isSignedIn() && request.resource.data.ownerId == request.auth.uid; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Secures the /matches/{matchId}/messages/{messageId} collection, ensuring only users in the match can access messages.
     * @path /matches/{matchId}/messages/{messageId}
     * @allow (create) User who is part of the match can create a message.
     * @allow (get) User who is part of the match can read a message.
     * @allow (list) User who is part of the match can list messages.
     * @allow (update) User who is part of the match can update a message.
     * @allow (delete) User who is part of the match can delete a message.
     * @deny (create) User who is not part of the match cannot create a message.
     * @principle Restricts access to messages based on match membership.
     */
    match /matches/{matchId}/messages/{messageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isParticipant(matchId) {
        return isSignedIn() && (get(/databases/$(database)/documents/matches/$(matchId)).data.user1Id == request.auth.uid || get(/databases/$(database)/documents/matches/$(matchId)).data.user2Id == request.auth.uid);
      }

      allow get: if isParticipant(matchId);
      allow list: if isParticipant(matchId);

      allow create: if isParticipant(matchId);
      allow update: if isParticipant(matchId);
      allow delete: if isParticipant(matchId);
    }

    /**
     * @description Secures the /startups/{startupId}/financialData/{financialDataId} collection.
     * @path /startups/{startupId}/financialData/{financialDataId}
     * @allow (create) User with access to the startup can create financial data.
     * @allow (get) User with access to the startup can read financial data.
     * @allow (list) User with access to the startup can list financial data.
     * @allow (update) User with access to the startup can update financial data.
     * @allow (delete) User without access to the startup cannot create financial data.
     */
    match /startups/{startupId}/financialData/{financialDataId} {
       function isSignedIn() {
        return request.auth != null;
      }

      function isStartupOwner(startupId) {
        return isSignedIn() && get(/databases/$(database)/documents/startups/$(startupId)).data.founderId == request.auth.uid;
      }

      allow get: if isStartupOwner(startupId);
      allow list: if isStartupOwner(startupId);

      allow create: if isStartupOwner(startupId);
      allow update: if isStartupOwner(startupId);
      allow delete: if isStartupOwner(startupId);
    }
  }
}
