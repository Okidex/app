rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to logos and avatars
    match /logos/{allPaths=**} {
      allow read;
    }
    match /avatars/{allPaths=**} {
      allow read;
    }

    // Allow authenticated users to write to their own avatar directory
    match /avatars/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to write logos
    match /logos/{logoId} {
        allow write: if request.auth != null;
    }
  }
}
