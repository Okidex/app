rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow read and write access for all authenticated users.
    // This is a permissive rule for development. For production, you should
    // implement more granular rules to control access based on user identity and file paths.
    // For example, only allow a user to write to their own avatar path.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}

